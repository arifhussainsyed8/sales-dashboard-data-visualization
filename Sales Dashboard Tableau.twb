      <aliases enabled='yes' />
      <column caption='AVG Profit Overall ' datatype='real' name='[AVGSALES OVerall (copy)_1323825902260227]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;AVG(&#10;    IF YEAR([Order Date]) =&#10;       { FIXED : MAX(YEAR([Order Date])) }&#10;    THEN [Total Current year sales (copy)_4279243804532739]&#10;    END&#10;)&#10;}' />
      </column>
      <column datatype='string' name='[Abbreviation]' role='dimension' type='nominal' />
      <column caption='Avg Profit State wise ' datatype='real' name='[Avg sales State wise (copy)_1323825902477316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED ([State/Province]): AVG([Total Current year sales (copy)_4279243804532739])}' />
      </column>
      <column caption='Avg sales State wise' datatype='real' name='[Calculation_1323825899679744]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED ([State/Province]): AVG([Calculation_4279243724578816])}' />
      </column>
      <column caption='AVG SALES Overall' datatype='real' name='[Calculation_1323825900003329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;AVG(&#10;    IF YEAR([Order Date]) =&#10;       { FIXED : MAX(YEAR([Order Date])) }&#10;    THEN [Calculation_4279243724578816]&#10;    END&#10;)&#10;}' />
      </column>
      <column caption='Sales Average Colour' datatype='string' name='[Calculation_1323825901355010]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1323825899679744] &lt; [Calculation_1323825900003329] THEN &apos;Below AVG&apos;&#10;ELSEIF [Calculation_1323825899679744] &gt; [Calculation_1323825900003329] THEN &apos;Above AVG&apos;&#10;ELSEIF [Calculation_1323825899679744] = [Calculation_1323825900003329] THEN &apos;AVG&apos;&#10;END' />
      </column>
      <column caption='Dynamic Measure' datatype='real' name='[Calculation_1323825910743046]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &apos;Total Current year sales&apos; THEN [Calculation_4279243724578816]&#10;WHEN &apos;Total Current year Profit&apos; THEN [Total Current year sales (copy)_4279243804532739]&#10;WHEN &apos;Total Current year Quantity&apos; THEN [Total Current year Profit (copy)_4279243806384135]&#10;END' />
      </column>
      <column caption='Total Current year sales' datatype='real' name='[Calculation_4279243724578816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='If YEAR([Order Date]) = {MAX(YEAR([Order Date]))} THEN [Sales]END' />
